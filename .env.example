# Local listener
HOST=127.0.0.1
PORT=48317

# Optional local client auth. If set, clients must send x-api-key or Bearer.
# Acts as a master key that bypasses per-user token tracking.
# PROXY_API_KEY=local-secret

# Token management. Set ADMIN_API_KEY to enable the dashboard at /admin and the
# /admin/api/* endpoints. Per-user tokens you create there gate /v1/messages and
# /v1/responses, and each request's token usage is recorded per token.
# Open the dashboard at http://<host>:<port>/admin and log in with ADMIN_API_KEY.
# ADMIN_API_KEY=admin-secret

# SQLite file storing tokens and usage records (created on first run).
# DB_PATH=~/.ccproxy/ccproxy.db

# Delete usage records older than this many days (runs daily). 0 disables pruning.
# USAGE_RETENTION_DAYS=90

# Serve the admin dashboard from this file at runtime instead of the embedded
# copy. Lets you edit the page without recompiling — just replace the file and
# refresh the browser. Falls back to the built-in page if unset or unreadable.
# DASHBOARD_PATH=/etc/ccproxy/dashboard.html

# codex uses ~/.codex/auth.json and refreshes ChatGPT OAuth tokens when needed.
# api-key uses OPENAI_API_KEY and https://api.openai.com/v1/responses.
OPENAI_AUTH_MODE=codex

# Codex OAuth / backend defaults match the installed OpenAI Codex CLI.
CODEX_AUTH_FILE=~/.codex/auth.json
CODEX_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
CHATGPT_BASE_URL=https://chatgpt.com/backend-api
CODEX_API_BASE=https://chatgpt.com/backend-api/codex
DEFAULT_INSTRUCTIONS=You are a helpful assistant.

# Upstream HTTP/SOCKS proxy. Prefer this over exporting global proxy vars.
# Supports http://, https:// and socks5:// URLs (reqwest CONNECT tunneling).
# UPSTREAM_PROXY_URL=http://127.0.0.1:6789

# Optional overrides for Codex OAuth login.
# CODEX_AUTHORIZE_URL=https://auth.openai.com/oauth/authorize
# CODEX_TOKEN_URL=https://auth.openai.com/oauth/token
# CODEX_OAUTH_SCOPE=openid profile email offline_access api.connectors.read api.connectors.invoke
# CODEX_OAUTH_REDIRECT_HOST=localhost

# Headless device-code login (no localhost callback; good for remote servers).
# Start: GET /auth/device/start  ->  open the returned verification_url and enter user_code
# Poll:  GET /auth/device/poll?device_auth_id=...&user_code=...  until status=complete
# CODEX_DEVICE_USERCODE_URL=https://auth.openai.com/api/accounts/deviceauth/usercode
# CODEX_DEVICE_TOKEN_URL=https://auth.openai.com/api/accounts/deviceauth/token
# CODEX_DEVICE_VERIFICATION_URL=https://auth.openai.com/codex/device
# CODEX_DEVICE_REDIRECT_URI=https://auth.openai.com/deviceauth/callback

# Model mapping for Anthropic clients (e.g. Claude Code sends claude-* names).
# Unmapped/gpt-* model names pass through unchanged.
# ANTHROPIC_DEFAULT_OPUS_MODEL=gpt-5.5
# ANTHROPIC_DEFAULT_SONNET_MODEL=gpt-5.5
# ANTHROPIC_DEFAULT_HAIKU_MODEL=gpt-5.4-mini

# API-key mode
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=https://api.openai.com/v1

# Optional JSON object merged into upstream request headers.
# OPENAI_EXTRA_HEADERS={"OpenAI-Organization":"org_..."}

# Timeouts (milliseconds)
# REQUEST_TIMEOUT_MS=600000
# STREAM_IDLE_TIMEOUT_MS=300000
